# ── Wildlife Interactive Map — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your own keys.
# Never commit .env to source control.

# eBird API key
# Get a free key at: https://ebird.org/api/keygen
# Used for: bird observation data, species frequency bar charts
VITE_EBIRD_API_KEY=your_ebird_api_key_here

# NPS Data API key
# Get a free key at: https://www.nps.gov/subjects/developer/get-started.htm
# Used for: national park wildlife topic data
VITE_NPS_API_KEY=your_nps_api_key_here

# Anthropic API key
# Get a key at: https://console.anthropic.com/
# Used for: generating AI fun-fact descriptions for animals without a hardcoded description
# Server-side only — set this in Vercel Dashboard → Settings → Environment Variables,
# NOT as a VITE_ variable (it must never be exposed to the browser).
ANTHROPIC_API_KEY=your_anthropic_api_key_here
