# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/

# ── Environment variables — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
scripts/rebuild-*.log

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json

# ── Vite cache ────────────────────────────────────────────────────────────────
.vite/

# ── eBird S&T GeoTIFF cache (large binary files, re-downloaded automatically) ─
scripts/geotiff-cache/

# ── Local script caches & scratch files (regenerated from wildlifeCache.js) ──
scripts/_*.cjs
scripts/_county_cache/
scripts/parkTips-cache.json
scripts/tipTargets.json
scripts/photoFetch-cache.json
scripts/rarityAudit_log.txt

# ── Claude Code local config ──────────────────────────────────────────────────
.claude/

# ── Vercel local config ───────────────────────────────────────────────────────
.vercel

# ── Downloaded / temp verification bundles (re-downloadable, large) ───────────
scripts/deployed-*.js
scripts/subcategoryAudit.json
